# ── LLM API Keys（必填：至少配置一个）──
# DeepSeek 推荐（最便宜，性价比最高）：https://platform.deepseek.com/api_keys
# OpenAI：https://platform.openai.com/api-keys
# Gemini：https://aistudio.google.com/apikey
# GLM（智谱）：https://open.bigmodel.cn/usercenter/apikeys

OPENAI_API_KEY=sk-xxx
GEMINI_API_KEY=xxx
DEEPSEEK_API_KEY=sk-xxx
GLM_API_KEY=xxx

# Default LLM provider: openai | gemini | deepseek | glm
LLM_PROVIDER=deepseek

# Database
DATABASE_URL=sqlite:///./data/academic_reviewer.db

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Server
HOST=127.0.0.1
PORT=8000

# Central sync server (leave empty if this is the central server)
# Example: http://your-server-ip:8000
SYNC_SERVER_URL=

# Instance name for identification in central dashboard
INSTANCE_NAME=
