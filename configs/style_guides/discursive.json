{
  "competition_type": "discursive",
  "description": "议论文/思辨写作风格指南 - 适用于 John Locke/Marshall Society 等写作竞赛",
  "iron_law": {
    "can_rewrite": ["spelling", "grammar", "punctuation", "Chinglish expressions"],
    "cannot_rewrite": ["sentence structure", "voice (active/passive)", "word choice (synonym substitution)", "paragraph rhythm and flow", "register shift (formal/informal)", "rhetorical strategy", "argumentative framing"]
  },
  "style_parameters": {
    "max_passive_ratio": 0.30,
    "min_ttr": 0.48,
    "max_avg_sentence_length": 30,
    "min_avg_sentence_length": 14,
    "preferred_voice": "active, conversational-academic hybrid"
  },
  "clarity_checks": {
    "no_run_on_sentences_for_subordinate_clauses": true,
    "no_sentence_fragments": true,
    "subject_verb_agreement": true,
    "article_usage": true,
    "no_dangling_modifiers": true
  },
  "expected_features": [
    "hook or engaging opening",
    "clear thesis statement",
    "signposting transitions between argument blocks",
    "varied sentence structures",
    "precise vocabulary",
    "effective use of rhetorical questions"
  ],
  "common_issues": [
    "Chinglish: 中文英语对照",
    "论证过于生硬",
    "缺少过渡和承接",
    "句式单调",
    "词汇贫乏"
  ]
}
