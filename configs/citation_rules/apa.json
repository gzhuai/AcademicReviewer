{
  "format": "APA 7th",
  "description": "APA第7版引文规范，适用于社会科学竞赛 (CTB等)",
  "in_text_patterns": [
    "(Author, Year)",
    "(Author & Author, Year)",
    "(Author et al., Year)",
    "Author (Year) argues..."
  ],
  "reference_entry_pattern": "^[A-Z][a-z]+,\\s+[A-Z]\\.(?:\\s*[A-Z]\\.)?\\s*\\(\\d{4}\\)\\.\\s+.+",
  "required_elements": ["author", "year", "title", "source"],
  "format_checks": {
    "hanging_indent": true,
    "alphabetical_order": true,
    "doi_present": "recommended",
    "issue_number": "if available"
  }
}
